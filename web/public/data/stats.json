{
  "position_groups": {
    "QB": {
      "label": "Quarterbacks",
      "positions": "QB",
      "stats": {
        "passing_yards": {
          "label": "Passing Yards",
          "agg": "sum",
          "format": "integer",
          "default_sort": "desc"
        },
        "passing_tds": {
          "label": "Passing TDs",
          "agg": "sum",
          "format": "integer",
          "default_sort": "desc"
        },
        "completions": {
          "label": "Completions",
          "agg": "sum",
          "format": "integer",
          "default_sort": "desc"
        },
        "attempts": {
          "label": "Pass Attempts",
          "agg": "sum",
          "format": "integer",
          "default_sort": "desc"
        },
        "passing_interceptions": {
          "label": "Interceptions Thrown",
          "agg": "sum",
          "format": "integer",
          "default_sort": "asc"
        },
        "passing_epa": {
          "label": "Passing EPA",
          "agg": "sum",
          "format": "decimal",
          "default_sort": "desc"
        },
        "passing_first_downs": {
          "label": "Passing First Downs",
          "agg": "sum",
          "format": "integer",
          "default_sort": "desc"
        },
        "sacks_suffered": {
          "label": "Times Sacked",
          "agg": "sum",
          "format": "integer",
          "default_sort": "asc"
        },
        "passing_air_yards": {
          "label": "Air Yards",
          "agg": "sum",
          "format": "integer",
          "default_sort": "desc"
        },
        "passing_yards_after_catch": {
          "label": "YAC (as passer)",
          "agg": "sum",
          "format": "integer",
          "default_sort": "desc"
        }
      }
    }
  },
  "filters": {
    "age": {
      "type": "numeric_range",
      "column": "age_at_game",
      "default": [0, 50]
    },
    "season_type": {
      "type": "enum",
      "column": "season_type",
      "options": ["REG", "POST", "ALL"],
      "default": "ALL"
    },
    "home_away": {
      "type": "enum",
      "column": "is_home",
      "options": ["ALL", "HOME", "AWAY"],
      "default": "ALL"
    },
    "min_games": {
      "type": "numeric_min",
      "column": "games_played",
      "default": 1
    }
  },
  "scopes": {
    "career": {
      "label": "Franchise Career",
      "group_by": ["player_id", "player_name"]
    },
    "season": {
      "label": "Single Season",
      "group_by": ["player_id", "player_name", "season"]
    },
    "game": {
      "label": "Single Game",
      "group_by": ["player_id", "player_name", "game_id", "game_date"]
    }
  }
}
